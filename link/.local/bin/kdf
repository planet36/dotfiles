#!/usr/bin/env python3
# SPDX-FileCopyrightText: Steven Ward
# SPDX-License-Identifier: MPL-2.0

# pylint: disable=invalid-name

'''
Derive a key from a password and salt using PBKDF2 and print its digest.
'''

__author__ = 'Steven Ward'
__license__ = 'MPL-2.0'
__version__ = '2026-07-12'

import argparse
import base64
import getpass
import hashlib
import os
import signal
import sys
from collections.abc import Callable

# Restore default SIGPIPE handling so broken pipes terminate silently, as in C.
signal.signal(signal.SIGPIPE, signal.SIG_DFL)


def get_pbkdf2_algorithms_available():
    '''<https://docs.python.org/3/library/hashlib.html#hashlib.pbkdf2_hmac>'''

    password = b''
    salt = b''
    iterations = 1
    for hash_algorithm in hashlib.algorithms_available:
        try:
            hashlib.pbkdf2_hmac(hash_algorithm, password, salt, iterations)
        except ValueError:
            pass
        else:
            yield hash_algorithm


valid_hash_algorithms = sorted(get_pbkdf2_algorithms_available())

# https://docs.python.org/3/library/base64.html
valid_formats: dict[str, Callable[[bytes], bytes]] = {
        'b16' : base64.b16encode,
        'b32' : base64.b32encode,
        'b32hex' : base64.b32hexencode,
        'b64-std' : base64.standard_b64encode,
        'b64-url' : base64.urlsafe_b64encode,
        'a85' : base64.a85encode,
        'b85' : base64.b85encode,
        'z85' : base64.z85encode,
    }


# pylint: disable=missing-function-docstring
# pylint: disable=too-many-locals
def main(argv: list[str] | None = None) -> int | None:

    default_hash_algorithm = 'sha256'
    default_format = 'b64-url'
    default_iterations = 1_000_000

    description_lines = (
            'Hash a string from standard input and print its hash digest.',
            )

    version_lines = (f'%(prog)s {__version__}',
                    f'License: {__license__}',
                    f'Written by {__author__}')

    parser = argparse.ArgumentParser(
            description='\n'.join(description_lines),
            formatter_class=argparse.RawTextHelpFormatter)

    parser.add_argument('-V', '--version', action='version', version='\n'.join(version_lines))

    parser.add_argument('-v', '--verbose', action='store_true',
            help='print diagnostics')

    parser.add_argument('-a', '--hash-algorithm', choices=valid_hash_algorithms,
            default=default_hash_algorithm, metavar='ALGORITHM',
            help='hash algorithm used to hash the string (default: %(default)s)\n'
                 '<https://docs.python.org/3/library/hashlib.html>')

    parser.add_argument('-f', '--format', choices=sorted(valid_formats),
            default=default_format, metavar='FORMAT',
            help='encoding of the printed hash (default: %(default)s)\n'
                 '<https://docs.python.org/3/library/base64.html>')

    parser.add_argument('-n', '--num-iterations', type=int, default=default_iterations,
            metavar='N', help='iteratively hash the string N times (default: %(default)s)')

    parser.add_argument('-s', '--silent', action='store_true',
            help="don't echo terminal input")

    args = parser.parse_args(argv)

    def print_verbose(s):
        if args.verbose:
            print(f"# {s}", file=sys.stderr)

    hash_algorithm = args.hash_algorithm
    fmt = args.format
    iterations = args.num_iterations
    silent = args.silent

    print_verbose(f'{hash_algorithm=}')
    print_verbose(f'{fmt=}')
    print_verbose(f'{iterations=}')
    print_verbose(f'{silent=}')

    # https://pymotw.com/3/getpass/index.html
    # "It is up to the caller to detect when the input stream is not a tty and
    # use an alternate method for reading in that case."

    password_prompt = ''
    salt_prompt = ''
    if args.verbose:
        password_prompt = 'Password: '
        salt_prompt = 'Salt: '

    try:
        if sys.stdin.isatty() and silent:
            password = getpass.getpass(prompt=password_prompt)
            salt = getpass.getpass(prompt=salt_prompt)
        else:
            print(password_prompt, end='', flush=True)
            password = sys.stdin.readline().rstrip(os.linesep)
            print(salt_prompt, end='', flush=True)
            salt = sys.stdin.readline().rstrip(os.linesep)
    except KeyboardInterrupt:
        print()
        return 130

    print_verbose(f"{password=}")
    print_verbose(f"{salt=}")

    try:
        result = hashlib.pbkdf2_hmac(hash_algorithm, password.encode(), salt.encode(), iterations)
        print(valid_formats[fmt](result).decode())
    except ValueError as err:
        print(f"Error: {err}", file=sys.stderr)
        return 1

    return 0


if __name__ == '__main__':
    sys.exit(main())
