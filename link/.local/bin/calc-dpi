#!/usr/bin/env python3
# SPDX-FileCopyrightText: Steven Ward
# SPDX-License-Identifier: MPL-2.0

# pylint: disable=invalid-name
# pylint: disable=missing-function-docstring

'''
Calculate the DPI of a display from its resolution and diagonal size.
'''

__author__ = 'Steven Ward'
__license__ = 'MPL-2.0'
__version__ = '2026-07-12'

import argparse
import math
import signal
import sys

# Restore default SIGPIPE handling so broken pipes terminate silently, as in C.
signal.signal(signal.SIGPIPE, signal.SIG_DFL)


def calcdpi(width_px: int, height_px: int, diagonal_in: float) -> float:
    return math.hypot(width_px, height_px) / diagonal_in


def resolution_arg(s: str) -> tuple[int, int]:
    parts = s.split('x')
    if len(parts) != 2:
        raise argparse.ArgumentTypeError(f"invalid resolution {s!r} (expected WIDTHxHEIGHT)")
    try:
        width, height = int(parts[0]), int(parts[1])
    except ValueError as err:
        raise argparse.ArgumentTypeError(f"invalid resolution {s!r}: {err}") from err
    if width <= 0 or height <= 0:
        raise argparse.ArgumentTypeError(
            f"invalid resolution {s!r} (width and height must be positive)")
    return (width, height)


def positive_int(s: str) -> int:
    value = int(s)
    if value <= 0:
        raise argparse.ArgumentTypeError("must be > 0")
    return value


def positive_float(s: str) -> float:
    value = float(s)
    if value <= 0:
        raise argparse.ArgumentTypeError("must be > 0")
    return value


def main(argv: list[str] | None = None) -> int | None:

    description_lines = (
            'Calculate the DPI from the given display dimensions.',
            '',
            'RESOLUTION is the display resolution in pixels, formatted as WIDTHxHEIGHT',
            '(default 1920x1080).  DIAGONAL_INCHES is the diagonal size in inches.',
            )

    epilog_lines = (
            'EXAMPLES',
            '',
            'calc-dpi 16',
            'calc-dpi 1920x1200 16',
            'calc-dpi --scale=1.1 1920x1200 24',
            "calc-dpi $(xdpyinfo | awk '/dimensions/{print $2}') 18",
            )

    version_lines = (f'%(prog)s {__version__}',
                    f'License: {__license__}',
                    f'Written by {__author__}')

    parser = argparse.ArgumentParser(
            description='\n'.join(description_lines),
            epilog='\n'.join(epilog_lines),
            formatter_class=argparse.RawTextHelpFormatter)

    parser.add_argument('-V', '--version', action='version', version='\n'.join(version_lines))

    parser.add_argument('-v', '--verbose', action='store_true',
            help='print diagnostics')

    parser.add_argument('-s', '--scale', type=positive_float, default=1.0, metavar='SCALE_FACTOR',
            help='scale factor to apply to the DPI (default: %(default)s)')

    parser.add_argument('--min', type=positive_int, default=72, metavar='MIN_DPI',
            help='minimum DPI (default: %(default)s)')

    parser.add_argument('--max', type=positive_int, default=400, metavar='MAX_DPI',
            help='maximum DPI (default: %(default)s)')

    parser.add_argument('resolution', nargs='?', type=resolution_arg, default=(1920, 1080),
            metavar='RESOLUTION',
            help='display resolution as WIDTHxHEIGHT (default: 1920x1080)')

    parser.add_argument('diagonal', type=positive_float, metavar='DIAGONAL_INCHES',
            help='diagonal display size in inches')

    args = parser.parse_args(argv)

    if args.min > args.max:
        parser.error(f"--min ({args.min}) must be <= --max ({args.max})")

    width_px, height_px = args.resolution
    diagonal_in = args.diagonal
    scale_factor = args.scale
    min_dpi = args.min
    max_dpi = args.max

    def print_verbose(s):
        """Print the message if verbose mode is on"""
        if args.verbose:
            print('#', s)

    print_verbose(f'{width_px=}')
    print_verbose(f'{height_px=}')
    print_verbose(f'{diagonal_in=}')
    print_verbose(f'{scale_factor=}')
    print_verbose(f'{min_dpi=}')
    print_verbose(f'{max_dpi=}')

    dpi = calcdpi(width_px, height_px, diagonal_in)
    print_verbose(f'{dpi=}')

    dpi *= scale_factor
    print_verbose(f'{dpi=}')

    # round() does round-half-even
    # Round-half-up is preferred, but this adequate
    dpi = round(dpi)
    print_verbose(f'{dpi=}')

    if dpi < min_dpi:
        dpi = min_dpi
    elif dpi > max_dpi:
        dpi = max_dpi

    print(dpi)

    return 0


if __name__ == '__main__':
    sys.exit(main())
