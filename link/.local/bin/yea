#!/usr/bin/env python3
# SPDX-FileCopyrightText: Steven Ward
# SPDX-License-Identifier: MPL-2.0

# pylint: disable=invalid-name

'''
yea (pronounced like "yay") is similar to the 'yes' command except an output limit
can be given.
See also <https://man7.org/linux/man-pages/man1/yes.1.html> and
<https://en.wikipedia.org/wiki/Yes_(Unix)>
'''

__author__ = 'Steven Ward'
__license__ = 'MPL-2.0'
__version__ = '2026-07-11'

import argparse
import decimal
import enum
import os
import signal
import sys
try:
    from number_str_to_decimal import number_str_to_decimal
    imported_module_number_str_to_decimal = True
except ModuleNotFoundError:
    number_str_to_decimal = decimal.Decimal
    imported_module_number_str_to_decimal = False

# Restore default SIGPIPE handling so broken pipes terminate silently, as in C.
signal.signal(signal.SIGPIPE, signal.SIG_DFL)

# Output buffer size (bytes). The default was chosen empirically: benchmark
# throughput across candidate sizes with the command below and pick the fastest.
# Override it at runtime with $YEA_MAX_BUF_SIZE.
#
#   $ hyperfine --time-unit millisecond --warmup=5 \
#       --parameter-scan YEA_MAX_BUF_SIZE 4096 40960 --parameter-step-size 4096 \
#       'YEA_MAX_BUF_SIZE="{YEA_MAX_BUF_SIZE}" yea --no-newline --bytes=10Gi'
DEFAULT_MAX_BUF_SIZE = 4096 * 4


def number_str_to_int(s: str) -> int:
    '''Convert the number string to an int.'''
    return int(number_str_to_decimal(s))


def get_max_buf_size() -> int:
    '''Get the output buffer size, overridable via $YEA_MAX_BUF_SIZE.'''
    s = os.environ.get('YEA_MAX_BUF_SIZE')
    if not s:
        return DEFAULT_MAX_BUF_SIZE
    try:
        result = int(s)
    except ValueError as e:
        raise SystemExit(f'invalid YEA_MAX_BUF_SIZE {s!r}: not an integer') from e
    if result <= 0:
        raise SystemExit(f'invalid YEA_MAX_BUF_SIZE {s!r}: must be positive')
    return result


class Mode(enum.Enum):
    '''How the output limit (if any) is counted.'''
    UNLIMITED = enum.auto()
    BYTES = enum.auto()
    LINES = enum.auto()


def non_empty_str(s: str) -> str:
    '''Ensure the string is not empty.'''
    if not s:  # None or empty
        raise argparse.ArgumentTypeError("may not be empty")
    return s


# pylint: disable=missing-function-docstring
def main(argv: list[str] | None = None) -> int | None:

    description_lines = [
            'Print a string repeatedly until the optional limit is reached.',
            '',
            'yea (pronounced like "yay") is similar to the \'yes\' command except:',
            '  1) an output limit may be given',
            '  2) trailing newlines may be omitted',
        ]

    epilog_lines = [
            'If NUM is negative, it is considered unlimited.',
        ]

    if imported_module_number_str_to_decimal:
        epilog_lines.extend([
            '',
            'NUM may have a multiplier suffix:',
            'k=10**3, M=10**6, G=10**9, Ki=2**10, Mi=2**20, Gi=2**30, etc.'
        ])

    epilog_lines.extend([
        '',
        f'The output buffer size (default {DEFAULT_MAX_BUF_SIZE} bytes) may be set with the',
        'YEA_MAX_BUF_SIZE environment variable. It tunes throughput but not output.',
    ])

    parser = argparse.ArgumentParser(
        description='\n'.join(description_lines),
        epilog='\n'.join(epilog_lines),
        formatter_class=argparse.RawTextHelpFormatter)

    parser.add_argument('-V', '--version', action='version', version='\n'.join((
        f'%(prog)s {__version__}',
        f'License: {__license__}',
        f'Written by {__author__}')))

    group = parser.add_mutually_exclusive_group()

    group.add_argument('-c', '--bytes',
                       metavar='NUM', type=number_str_to_int, default=-1,
                       help='print NUM bytes (including appended newlines,'
                            ' unless --no-newline given)')

    group.add_argument('-n', '--lines',
                       metavar='NUM', type=number_str_to_int, default=-1,
                       help='print NUM lines (or NUM copies of STRING if --no-newline given)')

    parser.add_argument('-o', '--no-newline',
                        action='store_true',
                        help='do not append trailing newlines')

    parser.add_argument('STRING',
                        nargs='*', type=non_empty_str, default=['y'],
                        help='the string to be repeated')

    args = parser.parse_args(argv)

    b = ' '.join(args.STRING).encode()

    if not args.no_newline:
        b += b'\n'

    m = max(get_max_buf_size() // len(b), 1)  # ensure it's positive

    buf = b * m

    if args.bytes >= 0:
        mode, items_remaining, items_in_buffer = Mode.BYTES, args.bytes, len(buf)
    elif args.lines >= 0:
        mode, items_remaining, items_in_buffer = Mode.LINES, args.lines, m
    else:
        mode, items_remaining, items_in_buffer = Mode.UNLIMITED, 0, 0

    try:
        match mode:
            case Mode.UNLIMITED:
                while True:
                    sys.stdout.buffer.write(buf)
            case Mode.BYTES | Mode.LINES:
                while items_remaining > items_in_buffer:
                    sys.stdout.buffer.write(buf)
                    items_remaining -= items_in_buffer

                if items_remaining > 0:
                    partial_buf = (b * items_remaining if mode is Mode.LINES
                                   else buf[:items_remaining])
                    sys.stdout.buffer.write(partial_buf)

    except KeyboardInterrupt:
        pass

    return 0


if __name__ == '__main__':
    sys.exit(main())
