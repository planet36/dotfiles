# pylint: disable=invalid-name

'''
Print stdin lines that match none of the given regular expressions.
'''

__author__ = 'Steven Ward'
__license__ = 'MPL-2.0'
__version__ = '2026-07-11'

import os
import re
import signal
import sys

# Restore default SIGPIPE handling so broken pipes terminate silently, as in C.
signal.signal(signal.SIGPIPE, signal.SIG_DFL)

try:
    patterns = tuple(re.compile(arg) for arg in sys.argv[1:])
except re.PatternError as e:
    sys.exit(f'{sys.argv[0]}: invalid pattern: {e}')

for line in sys.stdin:
    line = line.rstrip(os.linesep)
    if not any(p.search(line) for p in patterns):
        print(line)
