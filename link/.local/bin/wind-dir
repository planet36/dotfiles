# pylint: disable=invalid-name
# pylint: disable=missing-module-docstring

__author__ = 'Steven Ward'
__license__ = 'MPL-2.0'
__version__ = '2025-10-02'

import argparse
import math
import os
import signal
import sys

# Restore default SIGPIPE handling so broken pipes terminate silently, as in C.
signal.signal(signal.SIGPIPE, signal.SIG_DFL)

# https://en.wikipedia.org/wiki/Wind_direction

# Adapted from
# https://github.com/clieg/pwy/blob/84189c2a74e5efbc836c877b9ccad2cdf8874631/pwy/__main__.py#L132
def degrees_to_cardinal_dir_index(degrees: float) -> int:
    '''Convert degrees to an int representing the cardinal direction.'''
    return int((degrees % 360.0 + 11.25) / 45) % 8

# https://en.wikipedia.org/wiki/Cardinal_direction
card_dir = ('N', 'NE', 'E', 'SE', 'S', 'SW', 'W', 'NW')

# https://www.unicode.org/charts/PDF/U1F800.pdf
arrows = ('🢃', '🢇', '🢀', '🢄', '🢁', '🢅', '🢂', '🢆')

assert len(card_dir) == 8
assert len(card_dir) == len(arrows)


# pylint: disable=missing-function-docstring
def main(argv=None):

    description_lines = (
            'Read a wind direction in degrees from each line of stdin.',
            'Print an arrow pointing in the direction the wind blows toward.'
            )

    version_lines = (f'%(prog)s {__version__}',
                    f'License: {__license__}',
                    f'Written by {__author__}')

    parser = argparse.ArgumentParser(
            description='\n'.join(description_lines),
            formatter_class=argparse.RawTextHelpFormatter)

    parser.add_argument('-V', '--version', action='version', version='\n'.join(version_lines))

    parser.add_argument('-t', '--text', action='store_true',
            help='print the cardinal direction (e.g. NE) instead of an arrow')

    args = parser.parse_args(argv)

    labels = card_dir if args.text else arrows

    for line in sys.stdin:
        try:
            degrees = float(line.rstrip(os.linesep))
        except ValueError:
            continue
        if not math.isfinite(degrees):
            continue
        cardinal_dir_index = degrees_to_cardinal_dir_index(degrees)
        print(labels[cardinal_dir_index])

    return 0


if __name__ == '__main__':
    sys.exit(main())
