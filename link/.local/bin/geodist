#!/usr/bin/env python3
# SPDX-FileCopyrightText: Steven Ward
# SPDX-License-Identifier: MPL-2.0

# pylint: disable=invalid-name
# pylint: disable=missing-function-docstring

# All circular angles are in degrees.

'''
Calculate the distance between pairs of geodetic coordinates read from stdin.
'''

__author__ = 'Steven Ward'
__license__ = 'MPL-2.0'
__version__ = '2026-07-12'

import argparse
import signal
import sys

# https://geopy.readthedocs.io/en/stable/#module-geopy.distance
import geopy.distance
import geopy.point

# Restore default SIGPIPE handling so broken pipes terminate silently, as in C.
signal.signal(signal.SIGPIPE, signal.SIG_DFL)

possible_dist_funcs = {
        'geodesic': geopy.distance.geodesic,
        'great_circle': geopy.distance.great_circle,
        }


# pylint: disable=too-many-locals
def main(argv: list[str] | None = None) -> int | None:

    description_lines = (
            'Calculate the distance (in meters) between geodetic coordinates'
            ' (in decimal degrees).',
            '',
            'Pairs of geodetic coordinates, separated by whitespace on the same line,',
            'are read from stdin.  The coordinates are in the following order:',
            'LAT1 LON1 LAT2 LON2',
            'Any fields after the first four are ignored.',
            )

    epilog_lines = (
            'EXAMPLES',
            '',
            'cat <<EOT | geodist --method geodesic',
            '40.056667 -78.905833 38.889722 -77.008889',
            '40.056667 -78.905833 38.8977 -77.0365',
            '38.889722 -77.008889 38.8977 -77.0365',
            'EOT',
            '',
            'cat <<EOT | geodist --method great_circle',
            '40.056667 -78.905833 38.889722 -77.008889',
            '40.056667 -78.905833 38.8977 -77.0365',
            '38.889722 -77.008889 38.8977 -77.0365',
            'EOT',
            )

    version_lines = (f'%(prog)s {__version__}',
                    f'License: {__license__}',
                    f'Written by {__author__}')

    parser = argparse.ArgumentParser(
            description='\n'.join(description_lines),
            epilog='\n'.join(epilog_lines),
            formatter_class=argparse.RawTextHelpFormatter)

    parser.add_argument('-V', '--version', action='version', version='\n'.join(version_lines))

    parser.add_argument('-v', '--verbose', action='store_true',
            help='print diagnostics')

    parser.add_argument('-m', '--method', choices=possible_dist_funcs, default='geodesic',
            help='method for calculating distance (default: %(default)s)')

    args = parser.parse_args(argv)

    if args.verbose:
        print(f'# method={args.method!r}')

    dist_func = possible_dist_funcs[args.method]

    for line in sys.stdin:
        fields = line.split()
        if not fields: # skip blank lines
            continue
        try:
            (lat1_deg, lon1_deg, lat2_deg, lon2_deg) = map(float, fields[0:4])
            p1 = geopy.Point(lat1_deg, lon1_deg)
            p2 = geopy.Point(lat2_deg, lon2_deg)
        except ValueError as err:
            print('Error:', err, file=sys.stderr)
            return 1

        if args.verbose:
            print(f'# p1={p1!r} p2={p2!r}')

        distance = dist_func(p1, p2).meters
        print(f'{distance:.1f}')

    return 0


if __name__ == '__main__':
    sys.exit(main())
