# pylint: disable=invalid-name
# pylint: disable=missing-function-docstring
# pylint: disable=no-else-return
# pylint: disable=redefined-outer-name

'''
Python version of lolcat: colorize stdin with a cycling color palette.
'''

__author__ = 'Steven Ward'
__license__ = 'MPL-2.0'
__version__ = '2026-07-12'

import argparse
from collections.abc import Callable, Sequence
import enum
import io
import math
import os
import random
import re
import signal
import sys
import typing

import hsluv

# https://stackoverflow.com/a/14693789
#ansi_escape = re.compile(r'\x1B(?:[@-Z\\-_]|\[[0-?]*[ -/]*[@-~])', re.ASCII)

# Adapted from:
# https://github.com/busyloop/lolcat/blob/master/lib/lolcat/lol.rb
ansi_escape = re.compile(r'((?:\x1B(?:[ -\/]+.|[\]PX^_][^\x07\x1B]*|\[[0-?]*.|.))*)(.?)', re.ASCII)
incomplete_escape = re.compile(br'\x1B(?:[ -\/]*|[\]PX^_][^\x07\x1B]*|\[[0-?]*)$', re.ASCII)

def cycle_seq(seq: Sequence, i: int=0):
    while True:
        i %= len(seq)
        yield seq[i]
        i += 1

def reset_term():
    # Adapted from:
    # https://github.com/busyloop/lolcat/blob/master/lib/lolcat/lol.rb
    if sys.stdout.isatty():
        print('\x1B[m\x1B[?25h\x1B[?1;5;2004l', end='')

# Restore default SIGPIPE handling so broken pipes terminate silently, as in C.
signal.signal(signal.SIGPIPE, signal.SIG_DFL)

# pylint: disable=unused-argument
def signal_handler(signal_num, execution_frame):
    # Reset the terminal so an interrupt does not leave it in a colored state.
    reset_term()
    print()
    sys.exit(128 + signal_num)

signal.signal(signal.SIGINT, signal_handler)
signal.signal(signal.SIGTERM, signal_handler)

# https://numpy.org/doc/stable/reference/generated/numpy.linspace.html
# endpoint not included
def linspace(start, stop, num: int):
    step = (stop - start) / num
    for i in range(num):
        yield start + step * i

# Get the difference between the angles (degrees)
def get_angle_deg_diff(a1: float, a2: float) -> float:
    return abs(math.remainder(a2 - a1, 360))

# pylint: disable=non-ascii-name
# pylint: disable=too-many-arguments
# pylint: disable=too-many-positional-arguments
def get_cylinder_coord_dist(
        ρ1: float, φ1: float, z1: float,
        ρ2: float, φ2: float, z2: float) -> float:
    # ρ == radial distance [0, 100]
    # φ == azimuth (degrees) [0, 360)
    # z == height [0, 100]

    d1 = get_angle_deg_diff(φ1, φ2) / 360
    d2 = abs(ρ1 - ρ2) / 100
    d3 = abs(z1 - z2) / 100

    # This gives better results than Euclidean distance between cylindrical
    # coordinates.
    # https://math.stackexchange.com/a/3612602
    return math.hypot(d1, d2, d3)
    #return ρ1**2 + ρ2**2 - 2*ρ1*ρ2*math.cos(math.radians(φ1 - φ2)) + (z1 - z2)**2

def upscale_RGB(sRGB: tuple) -> tuple:
    return tuple((
        int(sRGB[0] * 255 + 0.5),
        int(sRGB[1] * 255 + 0.5),
        int(sRGB[2] * 255 + 0.5)
        ))

# pylint: disable=missing-class-docstring
@enum.unique
class ColorSpace(enum.Enum):
    HSLUV = enum.auto()
    LOLCAT = enum.auto()

min_lightness = 0
max_lightness = 100

def color_space_arg(s: str) -> ColorSpace:
    try:
        return ColorSpace[s.upper()]
    except KeyError as err:
        raise argparse.ArgumentTypeError(
            f"invalid choice: {s!r} (choose from "
            f"{', '.join(ColorSpace.__members__)})") from err

def positive_int(s: str) -> int:
    value = int(s)
    if value <= 0:
        raise argparse.ArgumentTypeError("must be > 0")
    return value

def lightness_arg(s: str) -> float:
    value = float(s)
    if not min_lightness <= value <= max_lightness:
        raise argparse.ArgumentTypeError(
            f"must be within [{min_lightness}, {max_lightness}]")
    return value

def get_hsluv_color_dist(hsluv_color1, hsluv_color2) -> float:
    (H1, S1, L1) = hsluv_color1
    (H2, S2, L2) = hsluv_color2
    return get_cylinder_coord_dist(S1, H1, L1, S2, H2, L2)

ansi_color_num_to_hsluv_color = {}

# Adapted from:
# https://github.com/planet36/dotfiles/blob/main/link/.local/lib/python/x11_colors.py

rgb_vals = [0] + list(range(95, 255+1, 40))

# ANSI Colors (16..231)
for i in range(216):
    r = rgb_vals[(i // 36) % 6] / 255
    g = rgb_vals[(i // 6) % 6] / 255
    b = rgb_vals[i % 6] / 255
    num = i + 16
    ansi_color_num_to_hsluv_color[num] = hsluv.rgb_to_hsluv((r, g, b))

# ANSI Grays (232..255)
for i in range(24):
    v = (i * 10 + 8) / 255
    num = i + 232
    ansi_color_num_to_hsluv_color[num] = hsluv.rgb_to_hsluv((v, v, v))

del rgb_vals

def get_closest_ansi_color_num_from_hsluv(hsluv_color: tuple) -> int:

    closest_color_num = None
    min_color_dist = math.inf

    for (color_num, hsluv_color_i) in ansi_color_num_to_hsluv_color.items():
        color_dist = get_hsluv_color_dist(hsluv_color, hsluv_color_i)
        if color_dist < min_color_dist:
            min_color_dist = color_dist
            closest_color_num = color_num

    assert closest_color_num is not None
    return closest_color_num

def ansi_sgr_8bit(s: str, color_num: int, do_bg: bool = False, do_inv: bool = False) -> str:
    '''https://en.wikipedia.org/wiki/ANSI_escape_code#SGR_parameters'''

    esc_fmt = '\x1b[{};5;{}m'
    esc_inverse = '\x1b[7m'
    #esc_reset = '\x1b[0m'
    fg = 38
    bg = 48

    result = []

    if do_bg:
        esc_reset = f'\x1b[{bg+1}m'
        result.append(esc_fmt.format(bg, color_num))
    else:
        esc_reset = f'\x1b[{fg+1}m'
        result.append(esc_fmt.format(fg, color_num))

    if do_inv:
        result.append(esc_inverse)

    result.append(s)

    result.append(esc_reset)

    return ''.join(result)

def ansi_sgr_24bit(s: str, sRGBup, do_bg: bool = False, do_inv: bool = False) -> str:
    '''https://en.wikipedia.org/wiki/ANSI_escape_code#SGR_parameters'''
    # RGB color must be upscaled

    esc_fmt = '\x1b[{};2;{};{};{}m'
    esc_inverse = '\x1b[7m'
    #esc_reset = '\x1b[0m'
    fg = 38
    bg = 48

    result = []

    if do_bg:
        esc_reset = f'\x1b[{bg+1}m'
        result.append(esc_fmt.format(bg, sRGBup[0], sRGBup[1], sRGBup[2]))
    else:
        esc_reset = f'\x1b[{fg+1}m'
        result.append(esc_fmt.format(fg, sRGBup[0], sRGBup[1], sRGBup[2]))

    if do_inv:
        result.append(esc_inverse)

    result.append(s)

    result.append(esc_reset)

    return ''.join(result)

def generate_hsluv_colors(num_colors: int, S: float, L: float) -> tuple:
    '''
    S, L in [0, 100]
    '''

    start = 0
    stop = 360
    return tuple((H, S, L) for H in linspace(start, stop, num_colors))

def generate_RGB_colors(num_colors: int, lightness: float) -> tuple:
    '''
    lightness in [0, 1]
    '''

    start = 0
    stop = 1

    # inspired by lolcat
    return tuple((
        (math.cos(math.tau * float(x) + 0 * math.tau/3) + 1) / 2 * lightness,
        (math.cos(math.tau * float(x) + 2 * math.tau/3) + 1) / 2 * lightness,
        (math.cos(math.tau * float(x) + 1 * math.tau/3) + 1) / 2 * lightness
        ) for x in linspace(start, stop, num_colors))

# pylint: disable=too-many-branches
# pylint: disable=too-many-locals
# pylint: disable=too-many-statements
def main(argv: list[str] | None = None) -> int | None:

    # default values
    default_num_colors = 80
    default_color_space = ColorSpace.LOLCAT
    default_lightness_dict = {ColorSpace.LOLCAT: 100, ColorSpace.HSLUV: 70}

    description_lines = (
            'Python version of lolcat: colorize stdin with a cycling color palette.',
            )

    epilog_lines = (
            'The default lightness depends on the color space:',
            f'  {ColorSpace.LOLCAT.name}: {default_lightness_dict[ColorSpace.LOLCAT]}',
            f'  {ColorSpace.HSLUV.name}: {default_lightness_dict[ColorSpace.HSLUV]}',
            )

    version_lines = (f'%(prog)s {__version__}',
                    f'License: {__license__}',
                    f'Written by {__author__}')

    parser = argparse.ArgumentParser(
            description='\n'.join(description_lines),
            epilog='\n'.join(epilog_lines),
            formatter_class=argparse.RawTextHelpFormatter)

    parser.add_argument('-V', '--version', action='version', version='\n'.join(version_lines))

    parser.add_argument('-v', '--verbose', action='store_true',
            help='print diagnostics')

    parser.add_argument('-f', '--force', dest='force_color_output', action='store_true',
            help='force color output even if stdout is not a tty')

    parser.add_argument('-n', dest='num_colors', type=positive_int,
            default=default_num_colors, metavar='NUM',
            help='number of colors to cycle through (default: %(default)s)')

    parser.add_argument('-c', dest='color_space', type=color_space_arg,
            default=default_color_space, metavar='COLOR_SPACE',
            help=f'color space (default: {default_color_space.name})\n'
                 f'(valid: {", ".join(ColorSpace.__members__)})')

    parser.add_argument('-8', dest='use_true_color', action='store_false',
            help='print 8-bit ANSI colors instead of 24-bit true colors')

    parser.add_argument('-b', dest='do_bg', action='store_true',
            help='color the background instead of the foreground')

    parser.add_argument('-i', '--invert', dest='do_inv', action='store_true',
            help='invert the foreground and background')

    parser.add_argument('-s', '--seed', default=None,
            help='seed of the PRNG')

    parser.add_argument('-d', '--debug', action='store_true',
            help='print the colors, then exit')

    parser.add_argument('-l', dest='lightness', type=lightness_arg,
            default=None, metavar='LIGHTNESS',
            help=f'lightness within [{min_lightness}, {max_lightness}]')

    args = parser.parse_args(argv)

    if args.seed is not None:
        random.seed(args.seed)

    verbose = args.verbose
    force_color_output = args.force_color_output
    num_colors = args.num_colors
    color_space = args.color_space
    use_true_color = args.use_true_color
    do_bg = args.do_bg
    do_inv = args.do_inv
    debug = args.debug
    lightness = args.lightness

    if lightness is None:
        lightness = default_lightness_dict[color_space]

    def print_verbose(s):
        """Print the message if verbose mode is on"""
        if verbose:
            print(f"# {s}", file=sys.stderr)

    print_verbose(f'{force_color_output=}')
    print_verbose(f'{num_colors=}')
    print_verbose(f'{color_space=}')
    print_verbose(f'{use_true_color=}')
    print_verbose(f'{do_bg=}')
    print_verbose(f'{do_inv=}')
    print_verbose(f'{debug=}')
    print_verbose(f'{lightness=}')

    match color_space:
        case ColorSpace.HSLUV:
            saturation = 100
            hsluv_colors = generate_hsluv_colors(num_colors, saturation, lightness)
            sRGB_colors = tuple(map(hsluv.hsluv_to_rgb, hsluv_colors))

        case ColorSpace.LOLCAT:
            sRGB_colors = generate_RGB_colors(num_colors, lightness / 100)
            # When the RGB colors are converted to hsluv, the gamma is unapplied
            hsluv_colors = tuple(map(hsluv.rgb_to_hsluv, sRGB_colors))

    # colors holds upscaled RGB tuples (true color) or ANSI color numbers
    # (8-bit), and ansi_sgr is the matching formatter.  The code below is
    # written to handle either, so give both variables a widened static type.
    colors: tuple
    ansi_sgr: Callable[..., str]

    if use_true_color:
        sRGBup_colors = tuple(map(upscale_RGB, sRGB_colors))
        colors = sRGBup_colors
        ansi_sgr = ansi_sgr_24bit
    else:
        color_nums = tuple(map(get_closest_ansi_color_num_from_hsluv, hsluv_colors))
        colors = color_nums
        ansi_sgr = ansi_sgr_8bit

    # Undo mypy's per-branch narrowing back to the declared widened types.
    colors = typing.cast('tuple', colors)
    ansi_sgr = typing.cast('Callable[..., str]', ansi_sgr)

    print_verbose(f'{len(colors)=}')
    print_verbose(f'{colors=}')

    if debug:
        for color in colors:
            if use_true_color:
                color_hex = f'#{color[0]:02X}{color[1]:02X}{color[2]:02X}'
            else:
                color_hex = f'{color:02X}'

            if sys.stdout.isatty() or force_color_output:
                print(ansi_sgr(f'{color}\t{color_hex}', color, do_bg, do_inv))
            else:
                print(f'{color}\t{color_hex}')
        return 0

    i = random.randrange(num_colors)
    color_cycle = cycle_seq(colors, i)

    bytes_read = bytearray(io.DEFAULT_BUFFER_SIZE)

    # bytes_read is appended to this
    bytes_buf = bytearray()

    # sys.stdin.buffer is typed as BinaryIO, which does not declare readinto1.
    stdin_buffer = typing.cast(io.BufferedReader, sys.stdin.buffer)

    # bytes_read is not cleared in subsequent calls to readinto1
    while (num_bytes_read := stdin_buffer.readinto1(bytes_read)) is not None:

        if num_bytes_read == 0:
            # EOF
            break

        bytes_buf += bytes_read[0:num_bytes_read]

        try:
            text = bytes_buf.decode()
        except UnicodeDecodeError:
            # Incomplete multi-byte character at the end; keep reading bytes
            continue

        if incomplete_escape.search(bytes_buf):
            # Keep reading bytes
            continue

        if sys.stdout.isatty() or force_color_output:
            for line in text.splitlines(keepends=True):

                # lolcat does this
                if '\t' in line:
                    line = line.expandtabs()

                for (esc_seq, c) in ansi_escape.findall(line):
                    print(esc_seq, end='')
                    if len(c) > 0:
                        print(ansi_sgr(c, next(color_cycle), do_bg, do_inv), end='')

                if line.endswith(os.linesep):
                    i += 1
                    color_cycle = cycle_seq(colors, i)
                    print(end=os.linesep)
        else:
            print(text, end='')

        bytes_buf.clear()

    reset_term()

    return 0

if __name__ == '__main__':
    sys.exit(main())
