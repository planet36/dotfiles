#!/usr/bin/env python3
# SPDX-FileCopyrightText: Steven Ward
# SPDX-License-Identifier: MPL-2.0

# pylint: disable=invalid-name
# pylint: disable=missing-function-docstring

'''
Redirect an input stream to a file (usable even when it is the same file).
'''

__author__ = 'Steven Ward'
__license__ = 'MPL-2.0'
__version__ = '2026-07-12'

import argparse
import signal
import sys

# Restore default SIGPIPE handling so broken pipes terminate silently, as in C.
signal.signal(signal.SIGPIPE, signal.SIG_DFL)


def sink(out_file_name, mode):
    # Soak up all of stdin before opening (and possibly truncating) the output
    # file, so reading from and writing to the same file works.  Operate on raw
    # bytes so the passthrough is encoding-agnostic and binary-faithful.
    data = sys.stdin.buffer.read()
    # pylint: disable=unspecified-encoding
    with open(out_file_name, mode=mode + 'b') as out_file:
        out_file.write(data)


def main(argv: list[str] | None = None) -> int | None:

    description_lines = (
            'Redirect an input stream to a file.',
            '',
            'Usable even when the output file is the same as the input,',
            'because stdin is fully read before the file is opened.',
            )

    epilog_lines = (
            "This was inspired by the 'sink' program by Bernhard Voelker.",
            'https://lists.gnu.org/archive/html/coreutils/2021-01/msg00067.html',
            '',
            "This is similar to the 'sponge' program from moreutils.",
            'https://joeyh.name/code/moreutils/',
            )

    version_lines = (f'%(prog)s {__version__}',
                    f'License: {__license__}',
                    f'Written by {__author__}')

    parser = argparse.ArgumentParser(
            description='\n'.join(description_lines),
            epilog='\n'.join(epilog_lines),
            formatter_class=argparse.RawTextHelpFormatter)

    parser.add_argument('-V', '--version', action='version', version='\n'.join(version_lines))

    parser.add_argument('-v', '--verbose', action='store_true',
            help='print diagnostics')

    parser.add_argument('-w', dest='mode', action='store_const', const='w', default='w',
            help='open FILE for writing, truncating it first (default)')

    parser.add_argument('-x', dest='mode', action='store_const', const='x',
            help='open FILE for exclusive creation, failing if it already exists')

    parser.add_argument('-a', dest='mode', action='store_const', const='a',
            help='open FILE for writing, appending to the end of it if it exists')

    parser.add_argument('FILE', help='the file to write the input stream to')

    args = parser.parse_args(argv)

    if args.verbose:
        print(f'# mode={args.mode!r}')

    try:
        sink(args.FILE, args.mode)
    except OSError as err:
        print('Error:', err, file=sys.stderr)
        return 1

    return 0


if __name__ == '__main__':
    sys.exit(main())
