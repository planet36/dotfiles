#!/usr/bin/env python3
# SPDX-FileCopyrightText: Steven Ward
# SPDX-License-Identifier: MPL-2.0

# pylint: disable=invalid-name
# pylint: disable=missing-function-docstring

# inspired by
# https://github.com/bakfile/bak

'''
Print a command to create or restore a numbered backup of a file.
'''

__author__ = 'Steven Ward'
__license__ = 'MPL-2.0'
__version__ = '2026-07-12'

import argparse
import os.path
import re
import shlex
import signal
import sys

# Restore default SIGPIPE handling so broken pipes terminate silently, as in C.
signal.signal(signal.SIGPIPE, signal.SIG_DFL)


def get_bak_path(path: str) -> str:

    basename, ext = os.path.splitext(path)
    match = re.fullmatch(r'\.bak([0-9]+)', ext)
    if match:
        bak_n = int(match.group(1))
    else:
        basename = path
        bak_n = 1

    while True:
        bak_path = basename + ".bak" + str(bak_n)
        if not os.path.exists(bak_path):
            break
        bak_n += 1

    return bak_path


def get_unbak_path(path: str) -> str:

    basename, ext = os.path.splitext(path)
    match = re.fullmatch(r'\.bak([0-9]+)', ext)
    # pylint: disable=no-else-return
    if match:
        return basename
    else:
        return path


def main(argv: list[str] | None = None) -> int | None:

    description_lines = (
            'Print a command to create a backup of the given input file.',
            'The extension ".bakN" (where "N" is a positive integer) is appended to',
            'the backup file name.',
            )

    version_lines = (f'%(prog)s {__version__}',
                    f'License: {__license__}',
                    f'Written by {__author__}')

    parser = argparse.ArgumentParser(
            description='\n'.join(description_lines),
            formatter_class=argparse.RawTextHelpFormatter)

    parser.add_argument('-V', '--version', action='version', version='\n'.join(version_lines))

    parser.add_argument('-m', '--move', action='store_true',
            help="print 'mv' instead of 'cp'")

    parser.add_argument('-u', '--unbak', action='store_true',
            help='print a command to restore the original file from the given backup file')

    parser.add_argument('FILE', nargs='+', help='the file to back up')

    args = parser.parse_args(argv)

    cmd = 'mv' if args.move else 'cp'
    bak_func = get_unbak_path if args.unbak else get_bak_path

    for in_file_name in args.FILE:

        out_file_name = bak_func(in_file_name)

        if in_file_name != out_file_name:
            print(shlex.join((cmd, '--verbose', '--backup=numbered', '--',
                              in_file_name, out_file_name)))

    return 0


if __name__ == '__main__':
    sys.exit(main())
